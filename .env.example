# Cadence — environment configuration
# Copy to .env.local and fill in. The app runs WITHOUT these (in-memory store +
# rules-based categoriser); they unlock real persistence and the live model.

# Neon Postgres connection string (free tier). When unset, an in-memory store is
# used so the demo still runs locally.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Google AI Studio key (free tier) for the live Gemini categoriser + rationale.
# When unset, Cadence uses the deterministic rules baseline and says so.
# GEMINI_API_KEY="your-google-ai-studio-key"

# Optional explicit base URL for the AIS self-call (auto-detected from the
# request host and the deployment URL otherwise; only set if you need to override).
# NEXT_PUBLIC_APP_URL="https://your-deployment-url"
